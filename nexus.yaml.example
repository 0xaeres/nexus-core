# Nexus configuration — see ENGINEERING.md for the full schema.
# Dev defaults: Qdrant in Docker, embedding + reranker via local llama.cpp,
# council + enricher LLMs via an OpenAI-compatible cloud endpoint.

# Optional here; the first-run UI wizard can create/attach this at /setup.
skills_repo: ""
hierarchy_root: ./skills

# ---------------------------------------------------------------- Connectors
# You can leave this empty and add sources in the UI.
connectors: []

# Example static GitHub source:
# connectors:
#   - name: github
#     type: github
#     token: ${GITHUB_TOKEN}
#     repos: ["myorg/my-repo"]
#     watch: true

# ---------------------------------------------------------------- Storage
vector_store:
  url: http://localhost:6333
  collections:
    code: nexus_code
    text: nexus_text

# ---------------------------------------------------------------- Models
models:
  council:
    provider: deepinfra
    model: Qwen/Qwen3-Max-Thinking
    api_key: ${DEEPINFRA_API_KEY}
    base_url: https://api.deepinfra.com/v1/openai

  # Optional role-specific overrides. Omit to use models.council for all three.
  # drafter:
  #   provider: deepinfra
  #   model: Qwen/Qwen3-Max-Thinking
  #   api_key: ${DEEPINFRA_API_KEY}
  #   base_url: https://api.deepinfra.com/v1/openai
  # critic:
  #   provider: deepinfra
  #   model: Qwen/Qwen3-Max-Thinking
  #   api_key: ${DEEPINFRA_API_KEY}
  #   base_url: https://api.deepinfra.com/v1/openai
  # reviser:
  #   provider: deepinfra
  #   model: Qwen/Qwen3-Max-Thinking
  #   api_key: ${DEEPINFRA_API_KEY}
  #   base_url: https://api.deepinfra.com/v1/openai

  light:
    provider: deepinfra
    model: google/gemma-3-4b-it
    api_key: ${DEEPINFRA_API_KEY}
    base_url: https://api.deepinfra.com/v1/openai

  embedding:
    provider: jina-local
    model: jinaai/jina-embeddings-v4
    url: http://localhost:8080

  reranker:
    provider: jina-local
    model: jinaai/jina-reranker-v3
    url: http://localhost:8081

# ---------------------------------------------------------------- Ingestion
ingestion:
  enrich_chunks:
    docs: true
    code: true
  embed_batch_size: 16          # client-side request fanout; llama.cpp physical batch is EMBEDDER_UBATCH
  quality_gate_threshold: 0.3
  file_batch_size: 20
  read_concurrency: 5
  enricher_concurrency: 4

# ---------------------------------------------------------------- Server
server:
  host: 0.0.0.0
  port: 8000

# ---------------------------------------------------------------- Local state
storage:
  proposal_queue: ./data/proposals.db
  council_checkpoint: ./data/council.sqlite
