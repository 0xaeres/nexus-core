# Nexus configuration — see ENGINEERING.md for the full schema.
# Dev defaults: Qdrant in Docker, DeepInfra embeddings/reranker/council.
# Local Jina remains available for high-resource/offline machines.

# Optional here; the first-run UI wizard can create/attach this at /setup.
skills_repo: ""
hierarchy_root: ./skills

# ---------------------------------------------------------------- Connectors
# You can leave this empty and add sources in the UI.
connectors: []

# Example static GitHub source:
# connectors:
#   - name: github
#     type: github
#     token: ${GITHUB_TOKEN}
#     repos: ["myorg/my-repo"]
#     watch: true

# ---------------------------------------------------------------- Storage
vector_store:
  url: http://localhost:6333
  timeout_s: 120
  upsert_batch_size: 16
  collections:
    code: nexus_code
    text: nexus_text
  # Qdrant v1.18+ native TurboQuant. Applied on collection creation; changing
  # type/bits/dim later requires recreating collections or explicitly updating
  # them in Qdrant, then resyncing/reindexing products.
  quantization:
    enabled: true
    type: turboquant                  # turboquant only for now
    bits: bits4                       # bits4 best recall; bits2/bits1_5/bits1 compress more
    always_ram: true

# ---------------------------------------------------------------- Models
models:
  council:
    provider: deepinfra
    model: deepseek-ai/DeepSeek-V3
    api_key: ${DEEPINFRA_API_KEY}
    base_url: https://api.deepinfra.com/v1/openai
    temperature: 0.0

  # Optional role-specific overrides. Omit to use models.council for all three.
  # drafter:
  #   provider: deepinfra
  #   model: deepseek-ai/DeepSeek-V3
  #   api_key: ${DEEPINFRA_API_KEY}
  #   base_url: https://api.deepinfra.com/v1/openai
  #   temperature: 0.0
  # critic:
  #   provider: deepinfra
  #   model: deepseek-ai/DeepSeek-V3
  #   api_key: ${DEEPINFRA_API_KEY}
  #   base_url: https://api.deepinfra.com/v1/openai
  #   temperature: 0.0
  # reviser:
  #   provider: deepinfra
  #   model: deepseek-ai/DeepSeek-V3
  #   api_key: ${DEEPINFRA_API_KEY}
  #   base_url: https://api.deepinfra.com/v1/openai
  #   temperature: 0.0
  synthesizer:
    provider: deepinfra
    model: deepseek-ai/DeepSeek-V4-Pro
    api_key: ${DEEPINFRA_API_KEY}
    base_url: https://api.deepinfra.com/v1/openai
    temperature: 0.0

  chat_agent:
    provider: deepinfra
    model: deepseek-ai/DeepSeek-V4-Flash
    api_key: ${DEEPINFRA_API_KEY}
    base_url: https://api.deepinfra.com/v1/openai
    temperature: 0.0

  light:
    provider: deepinfra
    model: google/gemma-4-26B-A4B-it
    api_key: ${DEEPINFRA_API_KEY}
    base_url: https://api.deepinfra.com/v1/openai

  embedding:
    provider: deepinfra
    model: Qwen/Qwen3-Embedding-4B
    api_key: ${DEEPINFRA_API_KEY}
    base_url: https://api.deepinfra.com/v1/openai
    dim: 2560
    instruction_profile: qwen3

  reranker:
    provider: deepinfra
    model: Qwen/Qwen3-Reranker-4B
    api_key: ${DEEPINFRA_API_KEY}
    base_url: https://api.deepinfra.com/v1/inference

  # Local Jina profile for high-resource/offline machines. Switching embedding
  # model, instruction profile, dimension, or reranker score scale requires
  # resync and eval: instructions, score thresholds, chunk lengths, and vector
  # dimensions are the real compatibility risks.
  # embedding:
  #   provider: jina-local
  #   model: jinaai/jina-embeddings-v4
  #   url: http://localhost:8080
  #   dim: 2048
  #   instruction_profile: jina-v4
  #
  # reranker:
  #   provider: jina-local
  #   model: jinaai/jina-reranker-v3
  #   url: http://localhost:8081

# ---------------------------------------------------------------- Ingestion
ingestion:
  enrich_chunks:
    docs: false
    code: false
  embed_batch_size: 32          # client-side request fanout; llama.cpp physical batch is EMBEDDER_UBATCH
  quality_gate_threshold: 0.0
  file_batch_size: 50
  read_concurrency: 10
  batch_concurrency: 2
  enricher_concurrency: 4
  enrichment_worker:
    enabled: false
    poll_interval_s: 5.0
    max_attempts: 3

# ---------------------------------------------------------------- Server
server:
  host: 0.0.0.0
  port: 8000

# ---------------------------------------------------------------- Local state
storage:
  proposal_queue: ./data/proposals.db
  council_checkpoint: ./data/council.sqlite
