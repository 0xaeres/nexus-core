# Copy to .env and fill in. Never commit the real file.

# ---- Cloud LLM provider (production council, PR review, changelog) ----
DEEPINFRA_API_KEY=

# ---- Source connectors ----
GITHUB_TOKEN=
# CONFLUENCE_TOKEN=
# SLACK_TOKEN=

# ---- Webhooks ----
GITHUB_WEBHOOK_SECRET=

# ---- Neo4j (matches docker-compose defaults) ----
NEO4J_USER=neo4j
NEO4J_PASSWORD=nexuslocal

# ---- Langfuse (matches docker-compose defaults) ----
LANGFUSE_PUBLIC_KEY=pk-lf-local
LANGFUSE_SECRET_KEY=sk-lf-local
LANGFUSE_NEXTAUTH_SECRET=changeme-local-only-32-chars-abc
LANGFUSE_SALT=changeme-local-only-32-chars-xyz

# ---- Optional showcase provider ----
# ANTHROPIC_API_KEY=
