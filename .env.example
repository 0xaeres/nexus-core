# Copy to .env and fill in. Never commit the real file.

# ---- Cloud LLM provider (council + light/enricher) ----
DEEPINFRA_API_KEY=

# ---- Org skills repo publishing ----
# Used by first-run setup and proposal approval to create/clone/push the
# org-wide skills repository. This is NOT the product source token entered
# during product onboarding.
NEXUS_SKILLS_REPO_TOKEN=

# ---- Optional static source connectors ----
# Only needed when declaring static GitHub connectors in nexus.yaml. Product
# onboarding collects its own per-product source PAT in the UI.
GITHUB_TOKEN=

# ---- Encryption key — REQUIRED for connector secrets at rest ----
# Encrypts connector tokens stored in SQLite. Without this, secrets are
# stored in plaintext.
# Generate with:
#   uv run python -c "from nexus.auth.token_cipher import TokenCipher; print(TokenCipher.generate_key())"
NEXUS_TOKEN_KEY=

# ---- Deployed password/session security ----
# Local dev: leave NEXUS_ENV unset unless you want production config validation.
# Production: set NEXUS_ENV=production and use strong generated secrets.
NEXUS_ENV=
NEXUS_SECRET_KEY=
NEXUS_ADMIN_API_KEY=
NEXUS_BOOTSTRAP_ADMIN_EMAIL=
NEXUS_BOOTSTRAP_ADMIN_PASSWORD=
NEXUS_ALLOWED_ORIGINS=http://localhost:3000
NEXUS_ENABLE_LOCAL_FS_SOURCES=false

# ---- Oracle/Caddy deployment ----
NEXUS_API_DOMAIN=api.example.com
NEXUS_SKILLS_REPO=

# ---- Optional free-tier observability ----
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
NEXUS_TRACE_CONTENT=false
